# ── Required ──────────────────────────────────────────────────────────────────

# Secret key for signing JWT tokens and session cookies.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ── Optional ──────────────────────────────────────────────────────────────────

# Where to store the SQLite database and downloaded report files.
# Defaults to ./data
DATA_DIR=./data

# Server listen address and port
# HOST=0.0.0.0
# PORT=8080

# Admin account created on first startup (if no users exist yet)
# INITIAL_ADMIN_EMAIL=admin@example.com
# INITIAL_ADMIN_PASSWORD=changeme123

# Token lifetimes
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=30

# Enable Swagger UI and ReDoc at /api/docs and /api/redoc.
# Off by default — exposes full API schema to any authenticated user.
# Enable only for development/debugging.
# API_DOCS_ENABLED=true

# Show the "B2 API Call" inspector panels in the UI (groups, members, settings, etc.).
# Great for demos and learning; leave off in production to reduce noise.
# API_INSPECTOR_ENABLED=true

# ── Credential Vault ──────────────────────────────────────────────────────────
# When enabled, B2 member credentials (application_key_id + application_key)
# are encrypted with Fernet (AES-128-CBC + HMAC-SHA256) and stored in the DB.
# Admins can retrieve them later via GET /api/credentials/{account_id}.
#
# Generate a key with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# KEEP THIS KEY SECRET AND BACK IT UP. Lost key = unrecoverable credentials.
# CREDENTIAL_VAULT_ENABLED=true
# CREDENTIAL_VAULT_KEY=<base64-fernet-key>
